# === Vercel + Neon production wiring (plan 05-07) ===
# In Vercel Project Settings → Environment Variables, set per-scope (Production / Preview / Development):
#   STORAGE_DRIVER=vercel
#   BLOB_READ_WRITE_TOKEN=<auto-injected when you connect a Blob store via Vercel UI>
#   DATABASE_URL=<Neon connection string for the matching branch — use ?pgbouncer=true&connection_limit=1>
#   AUTH_SECRET=<generate via `openssl rand -base64 32`; placeholder here, real value Phase 6>
#   ADMIN_URL_SEGMENT=<random URL-safe slug, used in Phase 6+; placeholder here>
#   NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=<base64 key; required if Vercel runs multiple instances>
# GitHub Environment 'production' (plan 05-06) needs:
#   DATABASE_URL_PROD=<same as Vercel Production-scope DATABASE_URL — pulled by db-migrate.yml>

# === Database (BOOT-03, BOOT-09) ===
# Postgres connection string. Plan 07 wires Neon (Vercel side).
# Driver is selected automatically by host pattern:
#   - *.neon.tech / *.neon.build → @neondatabase/serverless (HTTP, stateless)
#   - anything else (OVH managed PG, localhost, etc.) → postgres-js (TCP, pooled, max=1 per function)
# Migrations: ONLY apply via `npm run db:generate` (writes versioned SQL to drizzle/) +
# the prod GitHub Action (plan 05-06). NEVER `drizzle-kit push` against a real DB.
DATABASE_URL=postgres://user:pass@host:5432/db

# === Storage (BOOT-04, BOOT-05) ===
# Selects the lib/storage driver implementation.
# Allowed values: vercel | s3
STORAGE_DRIVER=vercel
# Vercel Blob token (when STORAGE_DRIVER=vercel).
BLOB_READ_WRITE_TOKEN=

# S3-compatible storage (when STORAGE_DRIVER=s3) — OVH Object Storage etc.
# Reserved for Phase 10 cutover. Stub driver lives in src/lib/storage/s3.ts (plan 03).
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Phase 6 — Auth & Shell (Better Auth + hidden admin URL)
# ─────────────────────────────────────────────────────────────────────────

# AUTH_SECRET: signing key used by Better Auth for session cookie HMAC.
# Min 32 chars. Generate: openssl rand -base64 32
# Required in dev (.env.local) and in Vercel envs (Preview + Production).
AUTH_SECRET=

# APP_URL: server-side base URL for Better Auth callbacks and invitation/reset
# link generation. Used by `betterAuth({ baseURL: process.env.APP_URL })`.
# Dev: http://localhost:3000
# Prod: https://leasetic-matrice.vercel.app (or the OVH equivalent)
APP_URL=

# NEXT_PUBLIC_APP_URL: client-side base URL exposed to the browser bundle.
# Same value as APP_URL in each environment. Used by `createAuthClient({ baseURL })`.
NEXT_PUBLIC_APP_URL=

# ADMIN_URL_SEGMENT: env-driven dynamic segment for the hidden admin tree
# (per D-17/D-18). The admin layout 404s when params.adminSegment !== this value.
# Generate: openssl rand -base64 9 | tr -d '+=/`  (yields ~12 URL-safe chars)
# Rotate by changing the value and redeploying — admins must be notified
# out-of-band. Never log this value.
ADMIN_URL_SEGMENT=

# === Build / runtime ===
# Required on multi-instance OVH deployments (per STACK.md §1)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Set by Vercel automatically; on OVH set explicitly to git SHA via deploy script.
GIT_COMMIT_SHA=
